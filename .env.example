# ============================================================================
# Vaultspec A2A Orchestrator — Environment Variables
# ============================================================================
# Copy to .env and fill values as needed.
# MANDATORY = required for the described feature
# OPTIONAL  = has a default
# ============================================================================

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
# Used by LangSmith / LangGraph tracing.
# MANDATORY for tracing/evals
LANGSMITH_API_KEY=
# WARNING: Keep LANGSMITH_TRACING=false when running docker-compose with the
# mock-seeder service. The mock-seeder runs infinite loops and will generate
# unlimited traces, burning your LangSmith API quota rapidly.
# Set to true only for local dev/evals against real providers.
LANGSMITH_TRACING=false
# OPTIONAL: trace grouping name
LANGSMITH_PROJECT=vaultspec-dev
# OPTIONAL: self-hosted endpoint
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Legacy aliases (still supported by LangChain)
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=vaultspec-dev

# ── Provider API Keys ────────────────────────────────────────────────────────
# Configure at least one provider.
# Accepted as bare or VAULTSPEC_ prefixed names.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
OPENAI_API_KEY=
ZHIPU_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional: Figma MCP integration only
FIGMA_ACCESS_TOKEN=

# ── Server Configuration ─────────────────────────────────────────────────────
VAULTSPEC_HOST=0.0.0.0
VAULTSPEC_PORT=8000
# development | staging | production
VAULTSPEC_ENVIRONMENT=development
VAULTSPEC_LOG_LEVEL=info
VAULTSPEC_DATABASE_URL=sqlite+aiosqlite:///vaultspec.db
VAULTSPEC_WORKSPACE_ROOT=./workspaces
# ACP gateway backend: node (default, uses npm-installed index.js via Node.js)
# or binary (uses the precompiled Bun executable in src/vaultspec_a2a/bin/).
# node is the stable default per ADR-002 §5.1. binary mode is experimental —
# requires placing claude-agent-acp binary in src/vaultspec_a2a/bin/ first.
VAULTSPEC_ACP_BACKEND=node
# ACP-ENV-006: suppress interactive feedback survey and telemetry traffic in
# non-interactive ACP subprocess sessions. Both are injected unconditionally
# by the provider; these entries document the effective runtime values.
CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
VAULTSPEC_PROVIDER_TIMEOUT_SECONDS=120


# ── MCP Server (standalone) ──────────────────────────────────────────────────
# Base URL used by MCP tools for gateway API calls
VAULTSPEC_MCP_API_BASE_URL=http://localhost:8000
# Bind host/port for MCP streamable-http transport
VAULTSPEC_MCP_HOST=0.0.0.0
VAULTSPEC_MCP_PORT=8100

# ── API & CORS ───────────────────────────────────────────────────────────────
# JSON array or comma-separated list
# VAULTSPEC_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Worker Process ───────────────────────────────────────────────────────────
VAULTSPEC_WORKER_PORT=8001
VAULTSPEC_WORKER_URL=http://127.0.0.1:8001
# Set in production to protect internal control calls
VAULTSPEC_INTERNAL_TOKEN=
VAULTSPEC_AUTO_MIGRATE=true
VAULTSPEC_MAX_CONCURRENT_THREADS=5

# ── OpenTelemetry (OTel) ─────────────────────────────────────────────────────
# Used by telemetry instrumentation.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
# OPTIONAL: service identity
# OTEL_SERVICE_NAME=vaultspec-a2a
# OTEL_SERVICE_VERSION=0.1.0
# OPTIONAL: disable SDK or log spans to stdout
# OTEL_SDK_DISABLED=true
# OTEL_EXPORTER_CONSOLE=true

# ── Mock LLM (Docker / dev) ──────────────────────────────────────────────────
# Base URL for the mock LLM server (VidaiMock)
# MOCK_API_BASE=http://vidaimock:8100

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Dev proxy target for Vite server
# VITE_API_URL=http://localhost:8000
# Runtime base URL used by frontend API clients
# VITE_API_BASE_URL=http://localhost:8000

# ── CI / Output Flags ────────────────────────────────────────────────────────
# CI=true
# NO_COLOR=true
