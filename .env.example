# ============================================================================
# Vaultspec A2A Orchestrator — Environment Variables
# ============================================================================
# Copy to .env and fill values as needed.
# MANDATORY = required for the described feature
# OPTIONAL  = has a default
# ============================================================================

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
# Used by LangSmith / LangGraph tracing.
# MANDATORY for tracing/evals
LANGSMITH_API_KEY=
# WARNING: Keep LANGSMITH_TRACING=false when running docker-compose with the
# mock-seeder service. The mock-seeder runs infinite loops and will generate
# unlimited traces, burning your LangSmith API quota rapidly.
# Set to true only for local dev/evals against real providers.
LANGSMITH_TRACING=false
# OPTIONAL: trace grouping name
LANGSMITH_PROJECT=vaultspec-dev
# OPTIONAL: self-hosted endpoint
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Provider API Keys ────────────────────────────────────────────────────────
# Configure at least one provider.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
OPENAI_API_KEY=
ZHIPU_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional: Figma MCP integration only
FIGMA_ACCESS_TOKEN=

# ── Server Configuration ─────────────────────────────────────────────────────
VAULTSPEC_HOST=0.0.0.0
VAULTSPEC_PORT=8000
# development | staging | production
VAULTSPEC_ENVIRONMENT=development
VAULTSPEC_LOG_LEVEL=info
# Persistence backend — ADR-035: SQLite is the local/dev default.
# For production, set postgres + a postgresql+asyncpg:// URL.
VAULTSPEC_DATABASE_BACKEND=sqlite
VAULTSPEC_CHECKPOINT_BACKEND=sqlite
VAULTSPEC_DATABASE_URL=sqlite+aiosqlite:///vaultspec.db
# Dedicated checkpoint DB (optional — defaults to VAULTSPEC_DATABASE_URL).
# Uncomment for Postgres production:
# VAULTSPEC_DATABASE_BACKEND=postgres
# VAULTSPEC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/vaultspec
# VAULTSPEC_CHECKPOINT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vaultspec?sslmode=disable
VAULTSPEC_WORKSPACE_ROOT=./workspaces
# Override computed project/UI paths (Docker non-editable installs only)
# VAULTSPEC_PROJECT_ROOT=/app
# VAULTSPEC_UI_BUILD_DIR=/app/src/ui/dist
# ACP gateway backend: node (default, uses npm-installed index.js via Node.js)
# or binary (uses the precompiled Bun executable in src/vaultspec_a2a/bin/).
# node is the stable default per ADR-002 §5.1. binary mode is experimental —
# requires placing claude-agent-acp binary in src/vaultspec_a2a/bin/ first.
VAULTSPEC_ACP_BACKEND=node
# ACP-ENV-006: suppress interactive feedback survey and telemetry traffic in
# non-interactive ACP subprocess sessions. Both are injected unconditionally
# by the provider; these entries document the effective runtime values.
CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# Global timeout (seconds) for LLM provider API calls.
VAULTSPEC_PROVIDER_TIMEOUT_SECONDS=120


# ── Gateway URL ──────────────────────────────────────────────────────────────
# Base URL for reaching the gateway HTTP API (used by worker IPC + MCP tools).
# Auto-derived from VAULTSPEC_HOST + VAULTSPEC_PORT when not set (see Phase 3).
VAULTSPEC_GATEWAY_URL=http://localhost:8000
# Bind host/port for MCP streamable-http transport
VAULTSPEC_MCP_HOST=0.0.0.0
VAULTSPEC_MCP_PORT=8100

# ── API & CORS ───────────────────────────────────────────────────────────────
# JSON array or comma-separated list
# VAULTSPEC_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Worker Process ───────────────────────────────────────────────────────────
VAULTSPEC_WORKER_PORT=8001
VAULTSPEC_WORKER_HOST=127.0.0.1
VAULTSPEC_WORKER_URL=http://127.0.0.1:8001
# Set in production to protect internal control calls
VAULTSPEC_INTERNAL_TOKEN=
VAULTSPEC_MAX_CONCURRENT_THREADS=5
VAULTSPEC_AUTO_SPAWN_WORKER=true
VAULTSPEC_REPAIR_ON_STARTUP=true
# conservative | mark_repair_needed
VAULTSPEC_REPAIR_STRATEGY=conservative
VAULTSPEC_POSTGRES_REQUIRED=false
VAULTSPEC_SQLITE_BUSY_TIMEOUT_MS=5000
# SQLAlchemy connection pool (Postgres only)
VAULTSPEC_DB_POOL_SIZE=5
VAULTSPEC_DB_POOL_MAX_OVERFLOW=10

# ── Operational Tuning (OPTIONAL — shown with defaults) ──────────────────────
# Worker / circuit-breaker
# VAULTSPEC_WORKER_HEARTBEAT_TIMEOUT_SECONDS=90.0
# VAULTSPEC_CB_FAILURE_THRESHOLD=3
# VAULTSPEC_CB_RECOVERY_TIMEOUT_SECONDS=30.0
# Worker health-poll back-off
# VAULTSPEC_WORKER_POLL_INITIAL_INTERVAL_SECONDS=0.1
# VAULTSPEC_WORKER_POLL_MAX_INTERVAL_SECONDS=2.0
# VAULTSPEC_WORKER_POLL_BACKOFF_FACTOR=1.5
# VAULTSPEC_WORKER_POLL_LOG_INTERVAL_SECONDS=5.0
# Worker watchdog
# VAULTSPEC_WATCHDOG_POLL_INTERVAL_SECONDS=5.0
# VAULTSPEC_WATCHDOG_MAX_RETRIES=3
# VAULTSPEC_WATCHDOG_BACKOFF_BASE_SECONDS=2.0
# WebSocket
# VAULTSPEC_WS_HEARTBEAT_INTERVAL_SECONDS=30.0
# VAULTSPEC_WS_DEAD_CLIENT_TIMEOUT_SECONDS=90.0
# VAULTSPEC_WS_MAX_MESSAGE_BYTES=1048576
# Internal IPC
# VAULTSPEC_INTERNAL_MAX_FRAME_BYTES=1048576
# VAULTSPEC_INTERNAL_MAX_HTTP_BODY_BYTES=1048576
# VAULTSPEC_IPC_FLUSH_INTERVAL_SECONDS=0.05
# VAULTSPEC_IPC_MAX_FLUSH_RETRIES=3
# VAULTSPEC_IPC_RETRY_BACKOFF_BASE_SECONDS=0.1
# VAULTSPEC_IPC_MAX_EVENT_BUFFER=10000
# LangGraph / executor
# VAULTSPEC_GRAPH_RECURSION_LIMIT=100
# VAULTSPEC_MAX_CACHED_GRAPHS=32
# Event aggregator
# VAULTSPEC_TOOL_CALL_DEBOUNCE_SECONDS=0.1
# VAULTSPEC_PLAN_UPDATE_DEBOUNCE_SECONDS=0.25
# VAULTSPEC_CHUNK_FLUSH_INTERVAL_SECONDS=0.05
# VAULTSPEC_DEBOUNCE_MAP_MAX_ENTRIES=1000
# VAULTSPEC_CHUNK_BUFFER_MAX_BYTES=4096
# VAULTSPEC_TOOL_ARG_TRUNCATE_LEN=1000
# VAULTSPEC_EVENT_QUEUE_MAXSIZE=512
# VAULTSPEC_AGET_STATE_TIMEOUT_SECONDS=10.0
# Context / workspace sizing
# VAULTSPEC_CONTEXT_LIMIT_TOKENS=120000
# VAULTSPEC_CHARS_PER_TOKEN=4
# VAULTSPEC_ANCHOR_PATH_CAP=10
# VAULTSPEC_MAX_CONTEXT_REFS=50
# VAULTSPEC_VAULT_INDEX_CAP=50
# VAULTSPEC_MOUNT_TOKEN_CEILING=20000
# VAULTSPEC_MIN_REMAINING_TOKENS_FOR_MOUNT=100
# VAULTSPEC_TASK_QUEUE_PENDING_HORIZON=2
# ACP provider
# VAULTSPEC_ACP_STARTUP_TIMEOUT_SECONDS=300.0
# VAULTSPEC_ACP_FS_READ_MAX_BYTES=10485760
# VAULTSPEC_ACP_RPC_TIMEOUT_SECONDS=15.0
# VAULTSPEC_ACP_CHUNK_QUEUE_MAXSIZE=1024
# Gemini OAuth
# VAULTSPEC_OAUTH_EXPIRY_BUFFER_SECONDS=120
# MCP server
# VAULTSPEC_MCP_CREATE_TIMEOUT_SECONDS=30.0
# VAULTSPEC_MCP_QUERY_TIMEOUT_SECONDS=15.0
# VAULTSPEC_MCP_MAX_INITIAL_MESSAGE_CHARS=32000
# VAULTSPEC_MCP_PREVIEW_TRUNCATE_LEN=200

# ── OpenTelemetry (OTel) ─────────────────────────────────────────────────────
# Used by telemetry instrumentation.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
# OPTIONAL: service identity
# OTEL_SERVICE_NAME=vaultspec-a2a
# OTEL_SERVICE_VERSION=0.1.0
# OPTIONAL: disable SDK or log spans to stdout
# OTEL_SDK_DISABLED=true
# OTEL_EXPORTER_CONSOLE=true

# ── Mock LLM (Docker / dev) ──────────────────────────────────────────────────
# Base URL for the mock LLM server (VidaiMock)
# MOCK_API_BASE=http://vidaimock:8100

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Dev proxy target for Vite server
# VITE_API_URL=http://localhost:8000
# Runtime base URL used by frontend API clients
# VITE_API_BASE_URL=http://localhost:8000

# ── CI / Output Flags ────────────────────────────────────────────────────────
# CI=true
# NO_COLOR=true
