# ============================================================================
# Vaultspec A2A Orchestrator — Environment Variables
# ============================================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Variable precedence: bare ecosystem names (e.g. OPENAI_API_KEY) take
# precedence over VAULTSPEC_-prefixed equivalents. Both forms are accepted
# for all provider API keys.
#
# MANDATORY = required; server will not function correctly without this
# OPTIONAL  = has a working default; override only when needed
# ============================================================================


# ── LangSmith Tracing (ADR-027) ──────────────────────────────────────────────
# Required for Layer 2 (integration observation) and Layer 3 (agentevals).
# Without these, live graph runs are unobservable and the evaluation harness
# will not function. Obtain a key at https://smith.langchain.com
#
# Canonical names are LANGSMITH_* (current SDK convention).
# Legacy aliases LANGCHAIN_API_KEY / LANGCHAIN_TRACING_V2 / LANGCHAIN_PROJECT
# are also accepted but all new documentation uses LANGSMITH_* exclusively.

# [MANDATORY for tracing/eval] LangSmith API key
LANGSMITH_API_KEY=

# [MANDATORY for tracing/eval] Enable trace upload to LangSmith
LANGSMITH_TRACING=true

# [OPTIONAL] LangSmith project name — traces are grouped under this project.
# Use separate projects per environment (dev/staging/prod).
# Default: "default"
LANGSMITH_PROJECT=vaultspec-dev

# [OPTIONAL] LangSmith API endpoint. Override only for self-hosted instances.
# Default: https://api.smith.langchain.com
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# ── Provider API Keys ────────────────────────────────────────────────────────
# At least one provider must be configured for the backend to serve real
# agent runs. Multiple providers may be configured simultaneously.

# [OPTIONAL] Anthropic pay-as-you-go API key.
# Used by ProviderFactory for the "claude" provider when ACP OAuth is absent.
# Accepted as: ANTHROPIC_API_KEY or VAULTSPEC_ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# [OPTIONAL] Claude Code OAuth token.
# Preferred auth for ACP-based Claude access (Claude Code subscription billing,
# not per-token). Takes precedence over ANTHROPIC_API_KEY when both are set.
# Accepted as: CLAUDE_CODE_OAUTH_TOKEN or VAULTSPEC_CLAUDE_CODE_OAUTH_TOKEN
CLAUDE_CODE_OAUTH_TOKEN=

# [OPTIONAL] OpenAI API key.
# Required for the "openai" provider (ChatOpenAI). Compatible with any
# OpenAI-API-spec endpoint (Azure OpenAI, local vLLM, etc.).
# Accepted as: OPENAI_API_KEY or VAULTSPEC_OPENAI_API_KEY
OPENAI_API_KEY=

# [OPTIONAL] Zhipu AI API key (GLM series models).
# Required for the "zhipu" provider. Uses an OpenAI-compatible API.
# Accepted as: ZHIPU_API_KEY or VAULTSPEC_ZHIPU_API_KEY
ZHIPU_API_KEY=

# [OPTIONAL] Gemini-specific API key.
# Takes precedence over GOOGLE_API_KEY in the provider factory.
# Accepted as: GEMINI_API_KEY or VAULTSPEC_GEMINI_API_KEY
GEMINI_API_KEY=

# [OPTIONAL] Google Cloud / AI Studio API key.
# Fallback Gemini auth when GEMINI_API_KEY is absent.
# Also used by gemini_auth.py for OAuth token refresh.
# Accepted as: GOOGLE_API_KEY or VAULTSPEC_GOOGLE_API_KEY
GOOGLE_API_KEY=

# [OPTIONAL] Figma Personal Access Token.
# Required only for the Figma MCP server integration (UI development).
# Not used by the backend at runtime.
FIGMA_ACCESS_TOKEN=


# ── Server Configuration ─────────────────────────────────────────────────────

# [OPTIONAL] Bind host for the uvicorn server.
# 0.0.0.0 accepts all interfaces; 127.0.0.1 is local-only.
# Default: 0.0.0.0
VAULTSPEC_HOST=0.0.0.0

# [OPTIONAL] Bind port for the uvicorn server.
# Default: 8000
VAULTSPEC_PORT=8000

# [OPTIONAL] Runtime environment. Affects log verbosity and debug features.
# Values: development | staging | production
# Default: development
VAULTSPEC_ENVIRONMENT=development

# [OPTIONAL] Log level for structured logging output.
# Values: debug | info | warning | error | critical
# Default: info
VAULTSPEC_LOG_LEVEL=info

# [OPTIONAL] SQLAlchemy async database URL.
# SQLite is recommended for local dev. Switch to PostgreSQL for production:
#   postgresql+asyncpg://user:password@host:5432/dbname
# Default: sqlite+aiosqlite:///vaultspec.db
VAULTSPEC_DATABASE_URL=sqlite+aiosqlite:///vaultspec.db

# [OPTIONAL] Workspace root directory for agent working directories.
# Each thread receives a subdirectory: {workspace_root}/{thread_id}/
# Default: ./workspaces
VAULTSPEC_WORKSPACE_ROOT=./workspaces

# [OPTIONAL] Default LLM provider for new threads when not set in the request.
# Values: claude | openai | zhipu | gemini
# Default: claude
VAULTSPEC_DEFAULT_PROVIDER=claude

# [OPTIONAL] Default model name. Leave blank to use each provider's default.
# Examples: gpt-4o, claude-sonnet-4-6, glm-4, gemini-2.0-flash
# Default: (none — provider default)
VAULTSPEC_DEFAULT_MODEL=

# [OPTIONAL] Global timeout in seconds for LLM provider API calls.
# Increase for slow providers or long prompts.
# Default: 120
VAULTSPEC_PROVIDER_TIMEOUT_SECONDS=120

# [OPTIONAL] Per-node step timeout in seconds for LangGraph Pregel execution.
# A node exceeding this limit is cancelled; the graph surfaces a timeout error.
# Default: 300
VAULTSPEC_GRAPH_NODE_TIMEOUT_SECONDS=300


# ── API & CORS ────────────────────────────────────────────────────────────────

# [OPTIONAL] Public base URL of this server.
# Used by MCP tools for loopback REST calls. Must be reachable from the MCP
# server process (typically the same machine).
# Default: http://localhost:8000
VAULTSPEC_API_BASE_URL=http://localhost:8000

# [OPTIONAL] Allowed CORS origins (JSON array or comma-separated).
# Vite dev/preview ports are always included in development mode.
# In production, restrict to your actual frontend origin.
# Default: localhost:5173, localhost:4173, localhost:8000 variants
# VAULTSPEC_CORS_ALLOWED_ORIGINS=https://app.vaultspec.dev


# ── Worker Process ────────────────────────────────────────────────────────────
# The worker executes agent graph runs. In development it is auto-spawned as a
# child process. In Docker/systemd it runs as an independent service.

# [OPTIONAL] Internal worker HTTP port. Must not conflict with VAULTSPEC_PORT.
# Default: 8001
VAULTSPEC_WORKER_PORT=8001

# [OPTIONAL] Worker base URL for control-plane dispatch calls.
# Change if running the worker on a separate host.
# Default: http://127.0.0.1:8001
VAULTSPEC_WORKER_URL=http://127.0.0.1:8001

# [OPTIONAL] Bearer token for control→worker internal API authentication.
# Leave blank in development (unauthenticated loopback).
# Set in production to prevent unauthorized direct worker access.
# Default: (none)
VAULTSPEC_INTERNAL_TOKEN=

# [OPTIONAL] Auto-spawn worker process on server startup.
# Set false when deploying with Docker Compose or systemd-managed services.
# Default: true
VAULTSPEC_AUTO_SPAWN_WORKER=true


# ── OTel Tracing (ADR-010) ───────────────────────────────────────────────────
# OTel traces are emitted for all graph runs, LLM calls, and API requests.
# In development, target a local Jaeger instance (docker compose includes one).
# LangSmith also ingests OTel traces automatically via LANGCHAIN_TRACING_V2.

# [OPTIONAL] OTLP gRPC endpoint for trace export.
# Use http://localhost:4317 when running Jaeger locally without Docker.
# Default (docker compose): http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# [OPTIONAL] Disable TLS for OTLP gRPC (safe for local Jaeger).
# Set false when exporting to a TLS-secured collector in production.
# Default: true
OTEL_EXPORTER_OTLP_INSECURE=true


# ── CI / Output Flags ────────────────────────────────────────────────────────

# [OPTIONAL] CI mode — suppresses interactive prompts, enables machine output.
# Automatically set by most CI systems (GitHub Actions, etc.).
# Default: false
# CI=true

# [OPTIONAL] Suppress ANSI colour codes in all output.
# Set if your log aggregator does not handle ANSI escape sequences.
# Default: false
# NO_COLOR=true
