# ============================================================================
# Vaultspec A2A Orchestrator — Integration Test Environment Variables
# ============================================================================
# Copy to .env and fill values as needed for integration tests.

# -- Database ------------------------------------------------------------------
# VAULTSPEC_DATABASE_URL=sqlite+aiosqlite:///test.sqlite

# -- Gateway -------------------------------------------------------------------
# VAULTSPEC_HOST=127.0.0.1
# VAULTSPEC_PORT=8000

# -- CI / Output Flags --------------------------------------------------------
# CI=true
# NO_COLOR=true
