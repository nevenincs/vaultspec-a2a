{
  "experimental": {
    "plan": true
  },
  "ui": {
    "useAlternateBuffer": false,
    "footer": {
      "hideContextPercentage": false
    },
    "inlineThinkingMode": "full",
    "hideBanner": true,
    "showMemoryUsage": true,
    "showCitations": true
  },
  "general": {
    "enablePromptCompletion": true
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "disabledTools": ["browser_file_upload", "browser_fill_form"]
    },
    "svelte": {
      "command": "npx",
      "args": ["-y", "@sveltejs/mcp@latest"]
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server@latest"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--no-usage-statistics"]
    },
    "uv": {
      "command": "uvx",
      "args": ["mcp-server-uv"]
    }
  }
}
