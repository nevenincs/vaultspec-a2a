          "const": "tool_call_start",
          "default": "tool_call_start",
          "title": "Type",
          "type": "string"
        },
        "thread_id": {
          "title": "Thread Id",
          "type": "string"
        },
        "agent_id": {
          "anyOf": [
            {
              "type": "string"
            },
