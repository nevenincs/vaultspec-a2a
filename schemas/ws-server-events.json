          "$ref": "#/$defs/PermissionOptionKind"
        }
      },
      "required": [
        "option_id",
        "name",
        "kind"
      ],
      "title": "PermissionOption",
      "type": "object"
    },
    "PermissionOptionKind": {
      "description": "User permission response options (mirrors ACP PermissionOption.kind).\n\nValues:\n    ALLOW_ONCE: Allow the tool call this time only.\n    ALLOW_ALWAYS: Allow all future invocations of this tool without prompting.\n    REJECT_ONCE: Deny the tool call this time only.\n    REJECT_ALWAYS: Deny all future invocations of this tool without prompting.",
      "enum": [
        "allow_once",
        "allow_always",
        "reject_once",
        "reject_always"
      ],
      "title": "PermissionOptionKind",
      "type": "string"
    },
    "PermissionRequestEvent": {
      "description": "Agent is requesting user permission to proceed.",
      "properties": {
        "type": {
          "const": "permission_request",
