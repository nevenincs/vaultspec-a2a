          "title": "Tool Call Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ToolKind"
        },
        "status": {
          "$ref": "#/$defs/ToolCallStatus",
          "default": "pending"
        },
        "locations": {
          "items": {
            "$ref": "#/$defs/ToolCallLocation"
          },
          "title": "Locations",
          "type": "array"
        },
        "content": {
          "items": {
            "discriminator": {
              "mapping": {
                "diff": "#/$defs/ToolCallContentDiff",
                "terminal": "#/$defs/ToolCallContentTerminal",
                "text": "#/$defs/ToolCallContentText"
              },
              "propertyName": "content_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ToolCallContentText"
              },
              {
                "$ref": "#/$defs/ToolCallContentDiff"
              },
              {
                "$ref": "#/$defs/ToolCallContentTerminal"
              }
            ]
          },
          "title": "Content",
          "type": "array"
        }
      },
      "required": [
        "thread_id",
        "timestamp",
        "sequence",
        "tool_call_id",
        "title",
        "kind"
      ],
      "title": "ToolCallStartEvent",
      "type": "object"
    },
