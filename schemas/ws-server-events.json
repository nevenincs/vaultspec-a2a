{
  "$defs": {
    "AgentLifecycleState": {
      "description": "Observable agent states exposed to the frontend.\n\nMaps to ADR-003 MCP states. Distinct from ``AgentState`` which tracks\ninternal process lifecycle (init/ready/running/error/done).",
      "enum": [
        "submitted",
        "idle",
        "working",
        "input_required",
        "auth_required",
        "completed",
        "failed",
        "cancelled"
      ],
      "title": "AgentLifecycleState",
      "type": "string"
    },
    "AgentStatusEvent": {
      "description": "Agent lifecycle state transition.",
      "properties": {
        "type": {
          "const": "agent_status",
          "default": "agent_status",
          "title": "Type",
          "type": "string"
        },
        "thread_id": {
          "title": "Thread Id",
          "type": "string"
        },
        "agent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Id"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "sequence": {
          "title": "Sequence",
          "type": "integer"
        },
        "metadata": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metadata"
        },
        "state": {
          "$ref": "#/$defs/AgentLifecycleState"
        },
        "node_name": {
          "title": "Node Name",
          "type": "string"
        },
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        }
      },
      "required": [
        "thread_id",
        "timestamp",
        "sequence",
        "state",
        "node_name"
      ],
      "title": "AgentStatusEvent",
      "type": "object"
    },
    "AgentSummary": {
      "description": "Lightweight agent descriptor for team status broadcasts.",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
